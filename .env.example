# ─────────────────────────────────────────────────────────────
#  MoodWave Backend — Environment Variables Template
#  Copy this to .env and fill in real values.
#  On Railway: set these in the Railway Dashboard → Variables tab.
# ─────────────────────────────────────────────────────────────

# ── Database (Railway auto-provides MYSQL_URL, OR set manually) ──
# Railway will auto-inject MYSQL_URL when you add a MySQL plugin.
# For local dev, use individual vars below:
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YourPassword
DB_NAME=mood_wave

# ── Flask ──────────────────────────────────────────────────────
SECRET_KEY=your_super_secret_flask_key_change_this
FLASK_ENV=production

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_change_this

# ── Spotify API ────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://YOUR-RAILWAY-APP.railway.app/api/spotify/callback

# ── YouTube API ────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
YOUTUBE_CLIENT_ID=your_youtube_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_oauth_client_secret

# ── Optional ───────────────────────────────────────────────────
HF_API_TOKEN=your_huggingface_token
